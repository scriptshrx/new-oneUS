// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String    @map("password_hash")
  firstName             String?   @map("first_name")
  lastName              String?   @map("last_name")
  role                  UserRole
  status                UserStatus

  // Clinic relationship (staff)
  clinic                Clinic?   @relation("ClinicStaff", fields: [clinicId], references: [id])
  clinicId              String?   @map("clinic_id")

  // Hospital relationship (admin/staff)
  hospital              Hospital? @relation("HospitalStaff", fields: [hospitalId], references: [id])
  hospitalId            String?   @map("hospital_id")

  // Patient relationship
  patient               Patient?  @relation("PatientUser", fields: [patientId], references: [id])
  patientId             String?   @unique @map("patient_id")

  // Various staff roles
  assignedReferrals     Referral[] @relation("ReferralAssignedStaff")
  assignedAppointments  Appointment[] @relation("AssignedStaff")

  // Portal chat/support
  portalMessages        PortalMessage[] @relation("StaffReplies")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  lastLogin             DateTime? @map("last_login")

  @@index([clinicId])
  @@index([hospitalId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  CLINIC_ADMIN
  CLINIC_STAFF
  HOSPITAL_ADMIN
  APP_ADMIN
  PATIENT
  INVESTOR
  PLATFORM_ADMIN

  @@map("user_roles")
}

enum UserStatus {
  ACTIVE
  PENDING_EMAIL_VERIFICATION
  PENDING_BAA_SIGNATURE
  SUSPENDED
  DELETED

  @@map("user_statuses")
}

// ============================================================================
// CLINIC ONBOARDING (STAGE 0)
// ============================================================================

model Clinic {
  id                    String    @id @default(cuid())
  name                  String
  clinicType            ClinicType @map("clinic_type")

  // Registration information
  npiNumber             String    @unique @db.VarChar(10) @map("npi_number")
  taxId                 String @map("tax_id")
  stateLicenseNumber    String @map("state_license_number")

  // Address
  streetAddress         String @map("street_address")
  city                  String
  state                 String    @db.Char(2)
  zipCode               String @map("zip_code")

  // Contact
  primaryPhone          String @map("primary_phone")
  workEmail             String    @unique @map("work_email")

  // Clinic operations
  infusionChairCount    Int @map("infusion_chair_count")
  treatmentTypesOffered String[] @map("treatment_types_offered")
  serviceArea           String[] @default([]) @map("service_area")

  // Platform status
  status                ClinicStatus
  baaSignedAt           DateTime? @map("baa_signed_at")
  baaSignedBy           String? @map("baa_signed_by")
  activatedAt           DateTime? @map("activated_at")

  // Relationships
  staff                 User[] @relation("ClinicStaff")
  patients              Patient[]
  referrals             Referral[]
  appointments          Appointment[]
  insuranceVerifications InsuranceVerification[]
  priorAuthorizations   PriorAuthorization[]
  voiceAgent            VoiceAgent?
  knowledgeBase         KnowledgeBase?
  callLogs              CallLog[]

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([npiNumber])
  @@index([state])
  @@map("clinics")
}

enum ClinicType {
  IV_THERAPY
  KETAMINE
  NAD_PLUS
  BIOLOGIC
  ANTIBIOTIC
  HORMONE_TRT
  HOME_INFUSION
  OTHER

  @@map("clinic_types")
}

enum ClinicStatus {
  REGISTERED
  BAA_PENDING
  ACTIVE
  SUSPENDED
  CANCELLED

  @@map("clinic_statuses")
}

// ============================================================================
// HOSPITAL/REFERRING INSTITUTION (STAGE 0 ALT)
// ============================================================================

model Hospital {
  id                    String    @id @default(cuid())
  name                  String

  // Registration information
  npiNumber             String    @unique @db.VarChar(10) @map("npi_number")
  taxId                 String @map("tax_id")
  stateLicenseNumber    String @map("state_license_number")

  // Address
  primaryOfficeAddress  String @map("primary_office_address")
  city                  String
  state                 String    @db.Char(2)
  zipCode               String @map("zip_code")

  // Contact
  primaryPhone          String @map("primary_phone")
  workEmail             String    @unique @map("work_email")

  // Contact person
  contactPersonFirstName String @map("contact_person_first_name")
  contactPersonLastName String @map("contact_person_last_name")
  contactPersonTitle    String @map("contact_person_title")

  // Platform status
  status                HospitalStatus
  baaSignedAt           DateTime? @map("baa_signed_at")
  baaSignedBy           String? @map("baa_signed_by")
  activatedAt           DateTime? @map("activated_at")

  // Relationships
  staff                 User[] @relation("HospitalStaff")
  referralPhysicians    ReferralPhysicianHospital[]

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([npiNumber])
  @@index([state])
  @@map("hospitals")
}

enum HospitalStatus {
  REGISTERED
  BAA_PENDING
  ACTIVE
  SUSPENDED
  CANCELLED

  @@map("hospital_statuses")
}

// ============================================================================
// REFERRAL PHYSICIANS FROM HOSPITALS
// ============================================================================

model ReferralPhysicianHospital {
  id                    String    @id @default(cuid())

  hospital              Hospital  @relation(fields: [hospitalId], references: [id])
  hospitalId            String @map("hospital_id")

  firstName             String @map("first_name")
  lastName              String @map("last_name")
  npiNumber             String    @unique @db.VarChar(10) @map("npi_number")
  specialty             String
  contactEmail          String? @map("contact_email")
  contactPhone          String? @map("contact_phone")

  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([hospitalId])
  @@index([npiNumber])
  @@map("referral_physicians_hospitals")
}

// ============================================================================
// PATIENTS
// ============================================================================

model Patient {
  id                    String    @id @default(cuid())

  // Basic demographics
  firstName             String @map("first_name")
  lastName              String @map("last_name")
  dateOfBirth           DateTime @map("date_of_birth")

  // Contact
  phoneNumber           String @map("phone_number")
  emailAddress          String @map("email_address")

  // Address
  address               String
  city                  String
  state                 String
  zipCode               String @map("zip_code")

  // Clinic relationship
  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  clinicId              String @map("clinic_id")

  // User account (optional - for patient portal login)
  user                  User?     @relation("PatientUser")

  // Insurance
  insurance             InsuranceInformation?

  // Clinical
  referrals             Referral[]
  intakeForm            PatientIntakeForm?
  hipaaConsent          HIPAAConsent?
  appointments          Appointment[]
  priorAuthorizations   PriorAuthorization[]
  portalMessages        PortalMessage[]

  // Pipeline status
  pipelineStage         PipelineStage @map("pipeline_stage")

  // Follow-up tracking
  lastFollowUpDate      DateTime? @map("last_follow_up_date")
  nextFollowUpDueDate   DateTime? @map("next_follow_up_due_date")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([clinicId])
  @@index([emailAddress])
  @@index([phoneNumber])
  @@map("patients")
}

enum PipelineStage {
  NEW_REFERRAL
  INSURANCE
  AUTHORIZATION
  SCHEDULING
  TREATMENT
  COMPLETE
  INACTIVE_ARCHIVED

  @@map("pipeline_stages")
}


model waitList{
  id String @id @default(cuid())
  email String
  joinedAt DateTime()  @default(now()) @@map('joined_at')
  @@map('wait_list')
}
// ============================================================================
// REFERRAL (STAGE 1)
// ============================================================================

model Referral {
  id                    String    @id @default(cuid())

  // Patient
  patient               Patient   @relation(fields: [patientId], references: [id])
  patientId             String @map("patient_id")

  // Clinic
  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  clinicId              String @map("clinic_id")

  // Referring physician
  referringPhysician    ReferringPhysician @relation(fields: [physicianId], references: [id])
  physicianId           String @map("physician_id")

  // Assigned staff for follow-up
  assignedStaff         User?     @relation("ReferralAssignedStaff", fields: [assignedStaffId], references: [id])
  assignedStaffId       String?   @map("assigned_staff_id")

  // Clinical details
  primaryDiagnosis      String @map("primary_diagnosis")
  diagnosisDescription  String @map("diagnosis_description")
  prescribedTreatment   String @map("prescribed_treatment")
  urgencyLevel          UrgencyLevel @map("urgency_level")
  clinicalNotes         String?   @db.Text @map("clinical_notes")

  // Document handling
  uploadedDocumentUrl   String? @map("uploaded_document_url")

  // Status
  status                ReferralStatus

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([patientId])
  @@index([clinicId])
  @@map("referrals")
}

enum UrgencyLevel {
  ROUTINE
  URGENT
  EMERGENT

  @@map("urgency_levels")
}

enum ReferralStatus {
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED

  @@map("referral_statuses")
}

model ReferringPhysician {
  id                    String    @id @default(cuid())

  firstName             String @map("first_name")
  lastName              String @map("last_name")
  npiNumber             String    @unique @db.VarChar(10) @map("npi_number")

  practice              String
  practicePhone         String @map("practice_phone")
  specialty             String

  referrals             Referral[]

  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([npiNumber])
  @@map("referring_physicians")
}

// ============================================================================
// PATIENT PORTAL & HIPAA (STAGE 2)
// ============================================================================

model HIPAAConsent {
  id                    String    @id @default(cuid())

  patient               Patient   @relation(fields: [patientId], references: [id])
  patientId             String    @unique @map("patient_id")

  // Digital signature capture
  signatureCaptured     Boolean   @default(false) @map("signature_captured")
  signedAt              DateTime? @map("signed_at")
  signatureIpAddress    String? @map("signature_ip_address")
  signatureUserAgent    String?   @db.Text @map("signature_user_agent")

  // Consent document
  consentDocumentUrl    String? @map("consent_document_url")

  status                ConsentStatus

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([patientId])
  @@map("hipaa_consents")
}

enum ConsentStatus {
  PENDING
  SIGNED
  EXPIRED

  @@map("consent_statuses")
}

// ============================================================================
// PATIENT INTAKE FORMS (STAGE 3)
// ============================================================================

model PatientIntakeForm {
  id                    String    @id @default(cuid())

  patient               Patient   @relation(fields: [patientId], references: [id])
  patientId             String    @unique @map("patient_id")

  treatmentType         ClinicType @map("treatment_type")

  // Common to all intake forms
  knownAllergies        String?   @db.Text @map("known_allergies")
  currentMedications    String?   @db.Text @map("current_medications")
  previousExperience    String?   @db.Text @map("previous_experience")

  // IV Therapy specific
  hydrationLevel        String? @map("hydration_level")
  bloodPressureHistory  String? @map("blood_pressure_history")
  pregnancyStatus       Boolean? @map("pregnancy_status")

  // Ketamine specific
  mentalHealthHistory   String?   @db.Text @map("mental_health_history")
  psychiatricMedications String? @map("psychiatric_medications")
  psychosisHistory      Boolean? @map("psychosis_history")
  maniaHistory          Boolean? @map("mania_history")
  substanceUseHistory   String?   @db.Text @map("substance_use_history")
  supportSystemAvailable Boolean? @map("support_system_available")

  // NAD+ specific
  currentSupplements    String?   @db.Text @map("current_supplements")
  cognitiveGoals        String? @map("cognitive_goals")
  energyBaseline        String? @map("energy_baseline")
  liverFunctionHistory  String? @map("liver_function_history")

  // Biologic specific
  diagnosisForBiologic  String? @map("diagnosis_for_biologic")
  previousBiologicUse   Boolean? @map("previous_biologic_use")
  tuberculosisScreening Boolean? @map("tuberculosis_screening")
  infectionHistory      String?   @db.Text @map("infection_history")
  recentLabsUrl         String? @map("recent_labs_url")

  // Antibiotic specific
  penicillinAllergy     Boolean? @map("penicillin_allergy")
  cultureResultsUrl     String? @map("culture_results_url")
  renalFunction         String? @map("renal_function")
  ivAccessHistory       String? @map("iv_access_history")

  // TRT / Hormone specific
  recentBloodworkUrl    String? @map("recent_bloodwork_url")
  currentHormoneTherapy String? @map("current_hormone_therapy")
  symptomsBeingTreated  String?   @db.Text @map("symptoms_being_treated")
  physicianClearanceUrl String? @map("physician_clearance_url")

  // Home infusion specific
  homeEnvironmentNotes  String?   @db.Text @map("home_environment_notes")
  caregiverAvailable    Boolean? @map("caregiver_available")
  ivAccessType          String? @map("iv_access_type")
  refrigerationAvailable Boolean? @map("refrigeration_available")
  emergencyContactAtHome String? @map("emergency_contact_at_home")

  // Status
  status                FormStatus

  completedAt           DateTime? @map("completed_at")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([patientId])
  @@map("patient_intake_forms")
}

enum FormStatus {
  INCOMPLETE
  SUBMITTED
  REVIEWED
  APPROVED

  @@map("form_statuses")
}

// ============================================================================
// INSURANCE VERIFICATION (STAGE 4)
// ============================================================================

model InsuranceInformation {
  id                    String    @id @default(cuid())

  patient               Patient   @relation(fields: [patientId], references: [id])
  patientId             String    @unique @map("patient_id")

  // Insurance details (from referral)
  insuranceCarrier      String @map("insurance_carrier")
  memberID              String @map("member_id")
  groupNumber           String @map("group_number")
  planType              PlanType @map("plan_type")

  // Eligibility tracking
  verifications         InsuranceVerification[]
  latestVerification    InsuranceVerification? @relation("LatestVerification")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([patientId])
  @@index([memberID])
  @@map("insurance_information")
}

enum PlanType {
  HMO
  PPO
  MEDICARE
  MEDICAID
  OTHER

  @@map("plan_types")
}

model InsuranceVerification {
  id                    String    @id @default(cuid())

  insurance             InsuranceInformation @relation(fields: [insuranceId], references: [id])
  insuranceId           String @map("insurance_id")

  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  clinicId              String @map("clinic_id")

  // Verification details (EDI 271 response)
  coverageActive        Boolean @map("coverage_active")
  infusionTherapyCovered Boolean @map("infusion_therapy_covered")
  annualDeductible      Float? @map("annual_deductible")
  deductibleMet         Float? @map("deductible_met")
  perVisitCopay         Float? @map("per_visit_copay")
  coinsurancePercentage Float? @map("coinsurance_percentage")

  // PA requirement
  priorAuthRequired     Boolean @map("prior_auth_required")

  // Status
  status                VerificationStatus
  failureReason         String? @map("failure_reason")

  requestedAt           DateTime @map("requested_at")
  respondedAt           DateTime? @map("responded_at")

  createdAt             DateTime  @default(now()) @map("created_at")

  insurance_latest      InsuranceInformation? @relation("LatestVerification", fields: [id], references: [id])

  @@index([insuranceId])
  @@index([clinicId])
  @@map("insurance_verifications")
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED

  @@map("verification_statuses")
}

// ============================================================================
// PRIOR AUTHORIZATION (STAGE 5)
// ============================================================================

model PriorAuthorization {
  id                    String    @id @default(cuid())

  patient               Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId             String @map("patient_id")

  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  clinicId              String @map("clinic_id")

  // PA details
  diagnosis             String
  prescribedDrug        String @map("prescribed_drug")
  requestedSessions     Int @map("requested_sessions")

  // Insurance submission
  covermymedsId         String? @map("coverymeds_id")
  insuranceSubmittedAt  DateTime @map("insurance_submitted_at")

  // PA decision
  status                PAuthStatus
  approvalNumber        String?   @unique @map("approval_number")
  approvalDate          DateTime? @map("approval_date")
  expiryDate            DateTime? @map("expiry_date")

  denialReason          String?   @db.Text @map("denial_reason")
  appealDeadline        DateTime? @map("appeal_deadline")

  // Session tracking
  approvedSessionsUsed  Int       @default(0) @map("approved_sessions_used")
  sessionsRemaining     Int? @map("sessions_remaining")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([patientId])
  @@index([clinicId])
  @@index([status])
  @@index([expiryDate])
  @@map("prior_authorizations")
}

enum PAuthStatus {
  PENDING
  APPROVED
  DENIED
  APPEAL_PENDING
  EXPIRED

  @@map("pauth_statuses")
}

// ============================================================================
// SCHEDULING & APPOINTMENTS (STAGE 6)
// ============================================================================

model Appointment {
  id                    String    @id @default(cuid())

  patient               Patient   @relation(fields: [patientId], references: [id])
  patientId             String @map("patient_id")

  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  clinicId              String @map("clinic_id")

  // Appointment details
  appointmentType       AppointmentType @map("appointment_type")
  scheduledDate         DateTime @map("scheduled_date")
  scheduledStartTime    DateTime @map("scheduled_start_time")
  scheduledEndTime      DateTime? @map("scheduled_end_time")

  // Assignment
  assignedNurse         User?     @relation("AssignedStaff", fields: [assignedNurseId], references: [id])
  assignedNurseId       String? @map("assigned_nurse_id")

  assignedChair         String? @map("assigned_chair")
  homeAddress           String? @map("home_address")

  // Treatment info
  treatmentType         String @map("treatment_type")
  drug                  String?
  dose                  String?

  // Status
  status                AppointmentStatus

  // Patient consent
  consentFormSigned     Boolean   @default(false) @map("consent_form_signed")
  consentSignedAt       DateTime? @map("consent_signed_at")

  // Linked records
  treatment             TreatmentRecord?
  followUps             FollowUp[]

  // Reminders sent
  confirmationSentAt    DateTime? @map("confirmation_sent_at")
  reminder48hSentAt     DateTime? @map("reminder_48h_sent_at")
  reminder24hSentAt     DateTime? @map("reminder_24h_sent_at")
  reminder2hSentAt      DateTime? @map("reminder_2h_sent_at")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([patientId])
  @@index([clinicId])
  @@index([scheduledDate])
  @@index([status])
  @@map("appointments")
}

enum AppointmentType {
  IN_CLINIC
  HOME_INFUSION

  @@map("appointment_types")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED

  @@map("appointment_statuses")
}

// ============================================================================
// TREATMENT RECORDS (STAGE 8)
// ============================================================================

model TreatmentRecord {
  id                    String    @id @default(cuid())

  appointment           Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId         String    @unique @map("appointment_id")

  // Drug administration
  drugName              String @map("drug_name")
  dose                  String
  route                 String
  lot_batch_number      String? @map("lot_batch_number")

  // Timing
  startTime             DateTime @map("start_time")
  endTime               DateTime @map("end_time")
  duration_minutes      Int @map("duration_minutes")

  // Admin provider
  administeringProvider String @map("administering_provider")

  // Session tracking
  sessionNumber         Int @map("session_number")
  totalSessionsPlanned  Int? @map("total_sessions_planned")

  // Clinical observations
  preInfusionVitals     String?   @db.Text @map("pre_infusion_vitals")
  postInfusionVitals    String?   @db.Text @map("post_infusion_vitals")

  adverseReactions      String?   @db.Text @map("adverse_reactions")
  clinicalNotes         String?   @db.Text @map("clinical_notes")
  deviationsFromProtocol String?  @db.Text @map("deviations_from_protocol")

  // Status
  status                TreatmentStatus

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([appointmentId])
  @@map("treatment_records")
}

enum TreatmentStatus {
  RECORDED
  REVIEWED
  BILLED

  @@map("treatment_statuses")
}

// ============================================================================
// POST-TREATMENT FOLLOW-UP (STAGE 9)
// ============================================================================

model FollowUp {
  id                    String    @id @default(cuid())

  appointment           Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId         String @map("appointment_id")

  // Follow-up timing
  scheduledFor          DateTime @map("scheduled_for")

  // Contact
  contactMethod         ContactMethod @map("contact_method")

  // Response tracking
  attemptedAt           DateTime? @map("attempted_at")
  responseReceived      Boolean   @default(false) @map("response_received")
  responseAt            DateTime? @map("response_at")
  response              String?   @db.Text

  // Concerns
  concernRaised         Boolean   @default(false) @map("concern_raised")
  concernDescription    String?   @db.Text @map("concern_description")
  escalatedToStaff      Boolean   @default(false) @map("escalated_to_staff")

  status                FollowUpStatus

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([appointmentId])
  @@index([scheduledFor])
  @@map("follow_ups")
}

enum ContactMethod {
  SMS
  VOICE
  EMAIL

  @@map("contact_methods")
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  FAILED
  ESCALATED

  @@map("follow_up_statuses")
}

// ============================================================================
// VOICE AGENT & COMMUNICATIONS
// ============================================================================

model VoiceAgent {
  id                    String    @id @default(cuid())

  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  clinicId              String    @unique @map("clinic_id")

  // Agent configuration
  agentStatus           VoiceAgentStatus @map("agent_status")
  agentId               String? @map("agent_id")

  // Call settings
  inboundEnabled        Boolean   @default(true) @map("inbound_enabled")
  outboundEnabled       Boolean   @default(true) @map("outbound_enabled")
  allowedCallHours      String? @map("allowed_call_hours")

  // Knowledge base link
  knowledgeBase         KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id])
  knowledgeBaseId       String? @map("knowledge_base_id")

  // Metrics
  totalCalls            Int       @default(0) @map("total_calls")
  successfulCalls       Int       @default(0) @map("successful_calls")

  callLogs              CallLog[]

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([clinicId])
  @@map("voice_agents")
}

enum VoiceAgentStatus {
  ACTIVE
  INACTIVE
  TRAINING
  DISABLED

  @@map("voice_agent_statuses")
}

model CallLog {
  id                    String    @id @default(cuid())

  voiceAgent            VoiceAgent @relation(fields: [voiceAgentId], references: [id])
  voiceAgentId          String @map("voice_agent_id")

  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  clinicId              String @map("clinic_id")

  // Call details
  phoneNumber           String @map("phone_number")
  callDirection         CallDirection @map("call_direction")
  purpose               CallPurpose

  // Call recording
  startTime             DateTime @map("start_time")
  endTime               DateTime? @map("end_time")
  durationSeconds       Int? @map("duration_seconds")
  recordingUrl          String? @map("recording_url")

  // Transcript
  transcriptUrl         String? @map("transcript_url")
  transcriptText        String?   @db.Text @map("transcript_text")

  // Outcome
  callStatus            CallStatus @map("call_status")
  outcome               String?   @db.Text

  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([voiceAgentId])
  @@index([clinicId])
  @@index([startTime])
  @@map("call_logs")
}

enum CallDirection {
  INBOUND
  OUTBOUND

  @@map("call_directions")
}

enum CallPurpose {
  REFERRAL_INTAKE
  ELIGIBILITY_CHECK
  PA_STATUS
  APPOINTMENT_REMINDER
  FOLLOW_UP_CHECK
  REBOOK_OFFER
  OUTREACH
  OTHER

  @@map("call_purposes")
}

enum CallStatus {
  ANSWERED
  NO_ANSWER
  VOICEMAIL
  DECLINED

  @@map("call_statuses")
}

// ============================================================================
// KNOWLEDGE BASE & CHATBOT
// ============================================================================

model KnowledgeBase {
  id                    String    @id @default(cuid())

  clinic                Clinic    @relation(fields: [clinicId], references: [id])
  clinicId              String    @unique @map("clinic_id")

  // Content
  faqItems              FAQItem[]

  // Status
  lastUpdatedAt         DateTime  @updatedAt @map("last_updated_at")

  voiceAgents           VoiceAgent[]

  @@index([clinicId])
  @@map("knowledge_bases")
}

model FAQItem {
  id                    String    @id @default(cuid())

  knowledgeBase         KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  knowledgeBaseId       String @map("knowledge_base_id")

  question              String
  answer                String    @db.Text
  category              String

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([knowledgeBaseId])
  @@map("faq_items")
}

model PortalMessage {
  id                    String    @id @default(cuid())

  patient               Patient   @relation(fields: [patientId], references: [id])
  patientId             String @map("patient_id")

  // Message
  messageText           String    @db.Text @map("message_text")
  messageType           MessageType @map("message_type")

  // Auto-response details (if applicable)
  fromChatbot           Boolean   @default(false) @map("from_chatbot")
  chatbotConfidence     Float? @map("chatbot_confidence")

  // Staff reply (if applicable)
  staffReply            User?     @relation("StaffReplies", fields: [staffReplyFromId], references: [id])
  staffReplyFromId      String? @map("staff_reply_from_id")
  staffReplyAt          DateTime? @map("staff_reply_at")

  // Resolution
  resolved              Boolean   @default(false)
  needsClinicalReview   Boolean   @default(false) @map("needs_clinical_review")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([patientId])
  @@map("portal_messages")
}

enum MessageType {
  PATIENT_QUESTION
  AUTO_RESPONSE
  STAFF_REPLY

  @@map("message_types")
}

// ============================================================================
// CRM & PIPELINE TRACKING
// ============================================================================

model PipelineBoard {
  id                    String    @id @default(cuid())

  clinicId              String    @unique @map("clinic_id")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("pipeline_boards")
}

// ============================================================================
// AUDIT LOGGING
// ============================================================================

model AuditLog {
  id                    String    @id @default(cuid())

  // Entity info
  entityType            String @map("entity_type")
  entityId              String @map("entity_id")

  // Action
  action                String
  userId                String @map("user_id")

  // Change details
  previousValue         String?   @db.Text @map("previous_value")
  newValue              String?   @db.Text @map("new_value")

  ipAddress             String? @map("ip_address")
  userAgent             String?   @db.Text @map("user_agent")

  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
